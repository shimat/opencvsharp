<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
    <NoWarn>CA1303;CA2007</NoWarn>

    <!-- The default 32MB wasm heap is too small to even link the real OpenCV wasm binary. -->
    <WasmInitialHeapSize>268435456</WasmInitialHeapSize>

    <!--
      Some OpenCvSharp P/Invoke declarations (e.g. the text module's TextDetectorCNN) have no
      corresponding symbol in the wasm-built OpenCvSharpExtern.a - unlike the dynamically-linked
      Windows/Linux/macOS runtimes, wasm statically links everything, so any consumer app hits
      this at publish time regardless of whether it actually calls the affected API. Tracked
      separately; not calling those APIs here, so allow the link to proceed.
    -->
    <WasmAllowUndefinedSymbols>true</WasmAllowUndefinedSymbols>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.9" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="10.0.9" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\OpenCvSharp\OpenCvSharp.csproj" />
  </ItemGroup>

  <!--
    Consume the wasm native binding the same way a real NuGet consumer does: NativeFileReference
    resolves the P/Invoke module name from the native file's %(Filename). Importing the actual
    shipped .props (instead of hand-rolling a NativeFileReference here) means this test exercises
    the same file that ships in OpenCvSharp5.runtime.wasm, catching issues like #2039 (module name
    mismatch -> DllNotFoundException) and #2037 (OpenCL/UMat probe crashing on wasm) end-to-end.
  -->
  <Import Project="..\..\packaging\nuget\OpenCvSharp5.runtime.wasm.props" />

</Project>
